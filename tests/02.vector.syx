(setopt x #true)

;;;; Syx Vector Behavior Tests

;; Test: Literal Vector Instantiation
;; Expected: #true (Instance is truthy)
(let ((vec #(1 2 3)))
  (if vec #true #false))

;; Test: Vector count field access
;; Expected: 3
(#(10 20 30) 'count)

;; Test: Empty vector count
;; Expected: 0
(#() 'count)

;; Test: First element access (positive index)
;; Expected: 10
(#(10 20 30) 0)

;; Test: Last element access via signed wrap-around
;; Expected: 30
(#(10 20 30) -1)

;; Test: Negative index offset wrapping
;; Expected: 20
(#(10 20 30) -2)

;; Test: Out of bounds positive index
;; Expected: <throw: out of bound>
(#(1 2 3) 4)

;; Test: Out of bounds negative index
;; Expected: <throw: out of bound>
(#(1 2 3) -4)

;; Test: Functional Mutation (Indexed Setter)
;; Expected: 999
(let (vec #(10 20 30))
  (vec 1 999)
  (vec 1))

;; Test: Functional Mutation via negative index
;; Expected: 777
(let (vec #(10 20 30))
  (vec -1 777)
  (vec 2))

;; 2. PAIRS & LIST STRUCTURE
(cons 1 2)                  ; (1 . 2)
(cons 1 (cons 2 #n))       ; (1 2)
'(a . b)                    ; (a . b)
'(a b . c)                  ; (a b . c)
(car '(1 . 2))              ; 1
(cdr '(1 . 2))              ; 2
(car '(1 2 3))              ; 1
(cdr '(1 2 3))              ; (2 3)
(car (cdr '(1 2 3)))        ; 2

;; 3. TYPE PREDICATES
(number? 1)                 ; true
(number? 1.0)               ; true
(integer? 1)                ; true
(integer? 1.0)              ; false
(fractional? 1.0)           ; true
(string? "a")               ; true
(symbol? 'a)                ; true
(pair? '(a . b))            ; true
(list? '(a b c))            ; true
(list? '(a . b))            ; false
(nil? #n)                  ; true
(bool? #t)                  ; true

;; 4. EQUALITY LOGIC
(= 1 1.0)                   ; true
(= "abc" "abc")             ; true
(= '(1 2) '(1 2))           ; true
(= 'a 'a)                   ; true
(eq? 1 1)                   ; true
(eq? 1 1.0)                 ; false
(eq? "a" "a")               ; false
(eq? '(1) '(1))             ; false
(eq? 'a 'a)                 ; true

;; 5. SPECIAL FORMS & LOGIC
(quote (a b))               ; (a b)
(begin 1 2 3)               ; 3
(if #t 'yes 'no)            ; yes
(if #f 'yes 'no)            ; no
(if #f 'yes)                ; #n
(and 1 2 3)                 ; 3
(and #f 1)                  ; false
(or #f 5)                   ; 5
(cond ((= 1 2) 'no) ((= 1 1) 'yes) (else 'none)) ; yes

;; 6. DEFINITION & ASSIGNMENT
(define a 10)               ; #n
a                           ; 10
(set a 20)                  ; #n
a                           ; 20
(let ((x 1) (y 2)) (+ x y)) ; 3

;; 7. ARITHMETIC VARIADICS
(+)                         ; 0
(*)                         ; 1
(+ 1 2 3 4)                 ; 10
(- 10 5 2)                  ; 3
(* 2 3 4)                   ; 24
(/ 20 2 2)                  ; 5

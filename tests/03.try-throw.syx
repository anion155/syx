(setopt x true)

(try (throw 1)) ; ()
(try (throw 1) (catch)) ; ()
(try (throw 1) (catch a)) ; ()
(try (throw 1) (catch a 2)) ; 2
(try (throw 1) (catch a 2 3)) ; 3
(try (throw 1) (catch 2)) ; 2
(try (throw 1) (catch 2 3)) ; 3
(try (throw 1) (catch) (finally)) ; ()
(try (throw 1) (catch a) (finally)) ; ()
(try (throw 1) (catch a 2) (finally)) ; 2
(try (throw 1) (catch a 2 3) (finally)) ; 3
(try (throw 1) (catch 2) (finally)) ; 2
(try (throw 1) (catch 3) (finally)) ; 3


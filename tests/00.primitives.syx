; BASIC VALUES & LITERALS
(setopt x #t)

;; primitives should be evaluated to the exactly the same values
#n          ; (expected #n)
#nil        ; (expected #n)
#null       ; (expected #n)
()          ; (expected ())
#f       ; (expected #f)
#false    ; (expected #f)
#t       ; (expected #t)
#true        ; (expected #t)
123         ; (expected 123)
-123        ; (expected -123)
123.456     ; (expected 123.456)
-123.456    ; (expected -123.456)
"test"      ; (expected "test")

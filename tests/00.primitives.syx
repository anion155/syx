; BASIC VALUES & LITERALS
(setopt x #t)

;; primitives should be evaluated to the exactly the same values
#n          ; (expected #n)
#nil        ; (expected #n)
#null       ; (expected #n)
()          ; (expected ())
#f       ; (expected #f)
#false    ; (expected #f)
#t       ; (expected #t)
#true        ; (expected #t)
123         ; (expected 123)
-123        ; (expected -123)
123.456     ; (expected 123.456)
-123.456    ; (expected -123.456)
"test"      ; (expected "test")

;; quoted values should be evaluated as this exact raw values
'#n                     ; #n
'symbol                  ; symbol
'()                      ; ()
'(a b)                   ; (a b)
'(a b . c)               ; (a b . c)
'#f                      ; #f
'#false                   ; #f
'#t                      ; #t
'#true                    ; #t
'123                     ; 123
'-123                    ; -123
'123.456                 ; 123.456
'-123.456                ; -123.456
'"test"                  ; "test"
''"test"                 ; '"test"
'if                      ; if
'+                       ; +
'(lambda (a b) (+ a b))  ; (lambda (a b) (+ a b))

;; functions should be evaluated to actual function values
;; if                          ; ?<if>
;; +                           ; !<+>
;; (lambda (a b) (+ a b))      ; (#<> (a b) (+ a b))
;; (lambda test (a b) (+ a b)) ; (#<test> (a b) (+ a b))

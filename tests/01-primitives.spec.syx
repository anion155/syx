;; 1. BASIC VALUES & LITERALS
123                         ; 123
-45                         ; -45
1.23                        ; 1.23
.5                          ; 0.5
"quoted string"             ; "quoted string"
true                        ; #t
#t                          ; #t
false                       ; #f
#f                          ; #f
nil                         ; nil
''some-symbol               ; 'some-symbol

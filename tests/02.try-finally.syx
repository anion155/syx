(setopt x #true)

(define i 0)
(define (print-counter) (println "counter:" i) (set i (+ i 1)))

(try 1 (catch) (finally (print-counter))) ; ()
(try 1 (catch a) (finally (print-counter))) ; ()
(try 1 (catch a 2) (finally (print-counter))) ; 2
(try 1 (catch a 2 3) (finally (print-counter))) ; 3
(try 1 (catch 2) (finally (print-counter))) ; 2
(try 1 (catch 2 3) (finally (print-counter))) ; 3

(try (throw 1) (catch) (finally (print-counter))) ; ()
(try (throw 1) (catch a) (finally (print-counter))) ; ()
(try (throw 1) (catch a 2) (finally (print-counter))) ; 2
(try (throw 1) (catch a 2 3) (finally (print-counter))) ; 3
(try (throw 1) (catch 2) (finally (print-counter))) ; 2
(try (throw 1) (catch 2 3) (finally (print-counter))) ; 3
;; (try (throw 1)) ; Unhandled exception: 1
;; (try (throw 1) (finally)) ; Unhandled exception: 1
;; (try (throw 1) (catch (throw 2)) (finally)) ; Unhandled exception: 2
;; (try 1 (finally (throw 2))) ; Unhandled exception: 2
